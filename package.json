{
  "name": "hyfolio",
  "version": "0.1.4",
  "description": "Beautiful, CMS-ready website blocks you own. Add what you need, customize everything.",
  "author": "skillsdock",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hyfolio": "./dist/cli/index.js",
    "create-hyfolio": "./dist/cli/create-entry.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./render": {
      "types": "./dist/render.d.ts",
      "import": "./dist/render.js",
      "require": "./dist/render.cjs"
    }
  },
  "files": [
    "dist",
    "src/blocks",
    "src/templates",
    "src/registry",
    "src/primitives",
    "src/theme/presets",
    "src/payload",
    "templates",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nextjs",
    "payload",
    "cms",
    "blocks",
    "website",
    "shadcn",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillsdock/hyfolio.git"
  },
  "bugs": {
    "url": "https://github.com/skillsdock/hyfolio/issues"
  },
  "homepage": "https://github.com/skillsdock/hyfolio#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "payload": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "jiti": "^2.6.1",
    "prompts": "^2.4.2",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  }
}
